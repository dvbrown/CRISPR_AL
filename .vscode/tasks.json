{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Marimo: Edit Current File",
      "type": "shell",
      "command": "source scripts/activate_env.sh && marimo edit --watch --port 0 ${file}",
      "isBackground": true,
      "runOptions": {
        "instanceLimit": 99
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Starting marimo.*$",
          "endsPattern": "^.*Server is running.*$|^.*Uvicorn running.*$|^.*Running at.*$"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "showReuseMessage": false
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Marimo: Edit Headless (Remote)",
      "type": "shell",
      "command": "source scripts/activate_env.sh && marimo edit ${file} --headless --port 2718 --host 0.0.0.0",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Starting marimo.*$",
          "endsPattern": "^.*Server is running.*$|^.*Uvicorn running.*$"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "showReuseMessage": false
      }
    }
  ]
}
