/*
 * Default resource settings for all processes.
 * Override per-process with withName blocks below.
 */
process {
    cpus          = 1
    memory        = '8.GB'
    time          = '2.h'
    errorStrategy = 'terminate'

    withName: 'BUILD_FEATURES' {
        // DepMap co-essentiality correlation is memory-intensive
        memory = '32.GB'
        time   = '4.h'
        cpus   = 2
    }

    withName: 'RUN_SPLIT' {
        // RF uses n_jobs=-1; allocate cores accordingly
        memory = '8.GB'
        time   = '30.m'
        cpus   = 2
    }

    withName: 'RUN_REDUCED_SPLIT' {
        memory = '8.GB'
        time   = '30.m'
        cpus   = 2
    }

    withName: 'RUN_ABLATION' {
        // Ridge only — fast
        memory = '4.GB'
        time   = '10.m'
        cpus   = 1
    }

    withName: 'TRANSFER_CALIBRATION' {
        // Re-runs all 25 RF splits sequentially
        memory = '16.GB'
        time   = '2.h'
        cpus   = 2
    }

    withName: 'AGGREGATE_RESULTS|AGGREGATE_REDUCED|AGGREGATE_ABLATION|SUMMARY_REPORT' {
        memory = '4.GB'
        time   = '15.m'
        cpus   = 1
    }

    withName: 'VALIDATE_SCHEMA|VALIDATE_SCHEMA_B' {
        memory = '2.GB'
        time   = '10.m'
        cpus   = 1
    }

    // ── Design B processes ────────────────────────────────────────────────────

    withName: 'LOAD_SHARON_SCREEN|GENERATE_CROSS_SPLITS|AGGREGATE_CROSS_RESULTS|SUMMARY_REPORT_B' {
        memory = '8.GB'
        time   = '30.m'
        cpus   = 1
    }

    withName: 'RUN_CROSS_SPLIT' {
        memory = '8.GB'
        time   = '30.m'
        cpus   = 2
    }

    withName: 'RUN_CROSS_BASELINE' {
        memory = '4.GB'
        time   = '10.m'
        cpus   = 1
    }

    withName: 'TRANSFER_CALIBRATION_C2S|TRANSFER_CALIBRATION_S2C' {
        memory = '16.GB'
        time   = '2.h'
        cpus   = 2
    }
}
