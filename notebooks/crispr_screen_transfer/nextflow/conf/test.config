/*
 * Test profile: 2 splits, quick feature build, 10 RF trees.
 * Runs locally in < 5 minutes on real data.
 */
params {
    n_repeats               = 2
    n_estimators            = 10
    top_k_features          = 3
    ablation_drop_threshold = 0.01
    quick_features          = true   // zero-impute DepMap (skips expensive correlation step)

    // Design B test params
    n_repeats_b             = 2
}

process {
    executor = 'local'

    withName: 'BUILD_FEATURES' {
        memory = '8.GB'
        time   = '10.m'
        cpus   = 1
    }

    withName: 'RUN_SPLIT|RUN_REDUCED_SPLIT' {
        memory = '4.GB'
        time   = '5.m'
        cpus   = 1
    }

    withName: 'TRANSFER_CALIBRATION' {
        memory = '4.GB'
        time   = '10.m'
        cpus   = 1
    }

    withName: 'RUN_CROSS_SPLIT' {
        memory = '4.GB'
        time   = '5.m'
        cpus   = 1
    }

    withName: 'TRANSFER_CALIBRATION_C2S|TRANSFER_CALIBRATION_S2C' {
        memory = '4.GB'
        time   = '10.m'
        cpus   = 1
    }
}
