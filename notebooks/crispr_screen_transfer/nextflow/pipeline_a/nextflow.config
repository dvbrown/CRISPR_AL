/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    crispr-al/design_a Nextflow config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

// Global default parameters
params {
    // ── Data paths ────────────────────────────────────────────────────────────
    data_dir         = "${projectDir}/../../../../data/bulk"

    chen_screen_path = "${params.data_dir}/chen2019_venetoclax/BIOGRID-ORCS-SCREEN_1393-2.0.18.screen.tab.txt"
    ccle_path        = "${params.data_dir}/ccle_expression/OmicsExpressionProteinCodingGenesTPMLogp1.csv.gz"
    depmap_path      = "${params.data_dir}/depmap_crispr_gene_effect/CRISPRGeneEffect.csv.gz"
    reactome_path    = "${params.data_dir}/pathway_annotations/NCBI2Reactome_PE_Pathway.txt.gz"
    goa_path         = "${params.data_dir}/pathway_annotations/goa_human.gaf.gz"
    hallmarks_path   = "${params.data_dir}/pathway_annotations/h.all.v2024.1.Hs.symbols.gmt.gz"
    kegg_path        = "${params.data_dir}/pathway_annotations/c2.cp.kegg_legacy.v2024.1.Hs.symbols.gmt.gz"
    schema_path      = "${projectDir}/../../metrics.schema.json"

    // ── Output directories ────────────────────────────────────────────────────
    artifacts_dir    = "${projectDir}/../../artifacts"
    results_dir      = "${projectDir}/../../results"

    // ── Feature subset ────────────────────────────────────────────────────────
    features_subset_file    = "${projectDir}/../../artifacts/coess_features.txt"

    // ── Run parameters ────────────────────────────────────────────────────────
    n_repeats               = 25
    train_size              = 2000
    n_estimators            = 200
    top_k_features          = 5
    ablation_drop_threshold = 0.05
    quick_features          = false

    // ── Boilerplate ───────────────────────────────────────────────────────────
    help     = false
    tracedir = "${params.results_dir}/pipeline_info"
}

// Work directory: keep off home, use project scratch
workDir = "${projectDir}/../../../../work/design_a"

// Timestamp for trace files
def trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')

// Load base config
includeConfig 'conf/base.config'

// ── Profiles ──────────────────────────────────────────────────────────────────
profiles {
    standard {
        process.executor = 'local'
    }

    slurm {
        includeConfig 'conf/slurm.config'
    }

    test {
        includeConfig 'conf/test.config'
    }
}

// ── Shared environment ────────────────────────────────────────────────────────
def ENV_PATH = "/home/users/allstaff/brown.d/vast_project_Protein/Repos/CRISPR_AL/.micromamba/envs/crispr-al"

process {
    shell        = ['/bin/bash', '-euo', 'pipefail']
    beforeScript = """
        module load micromamba || true
        eval "\$(micromamba shell hook --shell=bash)"
        micromamba activate ${ENV_PATH} || { echo "[WARN] Could not activate micromamba env" >&2; }
    """.stripIndent()
}

env {
    PYTHONNOUSERSITE = 1
}

// ── Execution reports ─────────────────────────────────────────────────────────
timeline {
    enabled = true
    file    = "${params.tracedir}/execution_timeline_${trace_timestamp}.html"
}
report {
    enabled = true
    file    = "${params.tracedir}/execution_report_${trace_timestamp}.html"
}
trace {
    enabled = true
    file    = "${params.tracedir}/execution_trace_${trace_timestamp}.txt"
}
dag {
    enabled = true
    file    = "${params.tracedir}/pipeline_dag_${trace_timestamp}.svg"
}

manifest {
    name            = 'crispr-al/design_a'
    author          = 'dvbrown'
    description     = 'Design A: Within-Screen Holdout 5-Loop Autonomous Research Pipeline'
    nextflowVersion = '!>=23.04.0'
    version         = '1.0.0'
}
