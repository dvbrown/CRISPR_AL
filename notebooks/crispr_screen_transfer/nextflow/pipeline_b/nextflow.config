/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    crispr-al/design_b Nextflow config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

// Global default parameters
params {
    // ── Data paths ────────────────────────────────────────────────────────────
    data_dir           = "${projectDir}/../../../../data/bulk"

    sharon_screen_path = "${params.data_dir}/sharon2019_venetoclax/BIOGRID-ORCS-SCREEN_1402-2.0.18.screen.tab.txt"
    schema_path        = "${projectDir}/../../metrics.schema.json"

    // ── Output directories ────────────────────────────────────────────────────
    // artifacts_dir is shared: Design B reads Design A parquets from here
    artifacts_dir      = "${projectDir}/../../artifacts"
    results_dir        = "${projectDir}/../../results"

    // ── Feature subset (from Design A phase A optimisation) ───────────────────
    design_b_features_file = "${projectDir}/../../artifacts/design_b_features.txt"

    // ── Run parameters ────────────────────────────────────────────────────────
    n_repeats_b        = 30
    train_size         = 2000
    n_estimators       = 200

    // ── Boilerplate ───────────────────────────────────────────────────────────
    help     = false
    tracedir = "${params.results_dir}/pipeline_info"
}

// Work directory: isolated from Design A
workDir = "${projectDir}/../../../../work/design_b"

// Timestamp for trace files
def trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')

// Load base config
includeConfig 'conf/base.config'

// ── Profiles ──────────────────────────────────────────────────────────────────
profiles {
    standard {
        process.executor = 'local'
    }

    slurm {
        includeConfig 'conf/slurm.config'
    }

    test {
        includeConfig 'conf/test.config'
    }
}

// ── Shared environment ────────────────────────────────────────────────────────
def ENV_PATH = "/home/users/allstaff/brown.d/vast_project_Protein/Repos/CRISPR_AL/.micromamba/envs/crispr-al"

process {
    shell        = ['/bin/bash', '-euo', 'pipefail']
    beforeScript = """
        module load micromamba || true
        eval "\$(micromamba shell hook --shell=bash)"
        micromamba activate ${ENV_PATH} || { echo "[WARN] Could not activate micromamba env" >&2; }
    """.stripIndent()
}

env {
    PYTHONNOUSERSITE = 1
}

// ── Execution reports ─────────────────────────────────────────────────────────
timeline {
    enabled = true
    file    = "${params.tracedir}/execution_timeline_${trace_timestamp}.html"
}
report {
    enabled = true
    file    = "${params.tracedir}/execution_report_${trace_timestamp}.html"
}
trace {
    enabled = true
    file    = "${params.tracedir}/execution_trace_${trace_timestamp}.txt"
}
dag {
    enabled = true
    file    = "${params.tracedir}/pipeline_dag_${trace_timestamp}.svg"
}

manifest {
    name            = 'crispr-al/design_b'
    author          = 'dvbrown'
    description     = 'Design B: Cross-Screen Transfer 3-Loop Autonomous Research Pipeline'
    nextflowVersion = '!>=23.04.0'
    version         = '1.0.0'
}
