/*
 * Test profile: 2 splits per direction, 10 RF trees.
 * Runs locally in < 5 minutes on real data.
 */
params {
    n_repeats_b  = 2
    n_estimators = 10
}

process {
    executor = 'local'

    withName: 'RUN_CROSS_SPLIT' {
        memory = '4.GB'
        time   = '5.m'
        cpus   = 1
    }

    withName: 'TRANSFER_CALIBRATION_C2S|TRANSFER_CALIBRATION_S2C' {
        memory = '4.GB'
        time   = '10.m'
        cpus   = 1
    }
}
