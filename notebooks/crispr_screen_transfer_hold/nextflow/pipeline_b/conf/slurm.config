/*
 * SLURM cluster settings for Design B.
 * Adjust queue names to match your cluster configuration.
 */
process {
    executor = 'slurm'
    queue    = 'regular'

    withName: 'RUN_CROSS_SPLIT' {
        queue          = 'regular'
        memory         = '16.GB'
        time           = '1.h'
        cpus           = 8
        clusterOptions = '--nodes=1'
    }

    withName: 'TRANSFER_CALIBRATION_C2S|TRANSFER_CALIBRATION_S2C' {
        queue          = 'regular'
        memory         = '32.GB'
        time           = '4.h'
        cpus           = 8
        clusterOptions = '--nodes=1'
    }

    withName: 'LOAD_SHARON_SCREEN|GENERATE_CROSS_SPLITS|RUN_CROSS_BASELINE|AGGREGATE_CROSS_RESULTS' {
        queue  = 'regular'
        memory = '8.GB'
        time   = '30.m'
        cpus   = 1
    }
}
